{
  "name": "@haboumrad/bom-changelog",
  "version": "0.2.2",
  "description": "changelog generation using github, jira and confluence",
  "author": "",
  "private": false,
  "license": "MIT",
  "repository": "haboumrad/bom-changelog",
  "homepage": "https://github.com/haboumrad/bom-changelog/blob/main/README.md",
  "main": "dist/main.js",
  "bin": {
    "changelog-cli": "./dist/main.js"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --",
    "start:debug": "nest start --debug --watch --",
    "start:prod": "export NODE_ENV=prod && node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "export BOM_CONTEXT=test && jest",
    "test:watch": "export BOM_CONTEXT=test && jest --watch",
    "test:cov": "export BOM_CONTEXT=test && jest --coverage",
    "test:debug": "export BOM_CONTEXT=test && node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "engines": {
    "npm": ">=9.5.0",
    "node": ">=18.15.0"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "axios": "^1.14.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "conventional-commits-parser": "^3.2.4",
    "nest-commander": "^3.20.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@types/express": "^5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "25.5.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "30.3.0",
    "nest-commander-testing": "^3.5.1",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "roots": [
      "<rootDir>/test"
    ],
    "modulePaths": [
      "<rootDir>"
    ],
    "testRegex": ".*spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  }
}
